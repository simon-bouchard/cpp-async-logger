# Build directories (build/, build-asan/, build-tsan/, etc. — includes FetchContent's
# googletest checkout, which lives under build/_deps and shouldn't be vendored)
build/
build-*/
cmake-build-*/

# compile_commands.json is generated by CMake and symlinked into the repo root
# for clangd — regenerate with `cmake -B build`, don't commit it
compile_commands.json

# clangd/editor tooling — a stale compile_flags.txt left in the repo has
# silently overridden compile_commands.json before; never commit one
compile_flags.txt
.cache/

# Compiled objects / ad-hoc binaries
*.o
*.obj
*.out
a.out

# Artifacts created by running the logger locally or tests outside of build/
# (e.g. `./logger_demo` or `ctest` invoked from the repo root instead of build/)
test_logs
logs.txt
error.txt

# Editor swap files
*.swp
*.swo

# OS
.DS_Store
